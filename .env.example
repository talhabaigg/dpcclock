APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=dpcclock
DB_USERNAME=dpcclock
DB_PASSWORD=dpcclock

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Queue failure alerts (see config/queue-failure-alerts.php).
# Leave RECIPIENTS empty to default to all users with the 'admin' role.
QUEUE_FAILURE_ALERTS_ENABLED=true
QUEUE_FAILURE_ALERTS_RECIPIENTS=
QUEUE_FAILURE_ALERTS_THROTTLE_MINUTES=30
QUEUE_FAILURE_ALERTS_IGNORE_JOBS=
QUEUE_FAILURE_ALERTS_AI_ENABLED=true
QUEUE_FAILURE_ALERTS_AI_MODEL=gpt-4.1-mini
QUEUE_FAILURE_ALERTS_AI_TIMEOUT=15
QUEUE_FAILURE_DIGEST_ENABLED=true
QUEUE_FAILURE_DIGEST_TIME=08:00

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MEDIA_DISK=public

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=459254
REVERB_APP_KEY=u4kcr1cnv3378upcpfy4
REVERB_APP_SECRET=zesyv1xwnkfai3lprrm4
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# CV (Computer Vision) Drawing Comparison Service
# Python microservice using OpenCV for deterministic change detection
CV_COMPARISON_SERVICE_URL=http://localhost:5050
CV_COMPARISON_TIMEOUT=120
CV_COMPARISON_ENABLED=true

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ClickSend SMS (https://dashboard.clicksend.com)
# CLICKSEND_FROM is the alphanumeric sender ID; leave blank until ClickSend
# approves the alpha tag (messages send from a shared numeric in the meantime).
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_FROM=

# Aconex / Oracle Smart Construction Platform API
# OAuth client must be a "User-Bound Integration" type (Resource Application:
# Aconex) created in the Lobby — see docs/aconex-api-integration-guide.md
ACONEX_CLIENT_ID=
ACONEX_CLIENT_SECRET=
ACONEX_LOBBY_URL=https://constructionandengineering.oraclecloud.com
ACONEX_INSTANCE=au1.aconex.com
